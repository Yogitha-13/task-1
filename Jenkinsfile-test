pipeline{
    agent any
    environment{
        IMAGE_NAME = "microdegree:latest"
    }
    stages{
        stage("git checkout"){
            steps{
                echo "checking out code from git repo"
            } 
        }
        stage("Building docker image"){
            steps{
                echo "building docker image using dockerfile"
                sh "docker build -t $IMAGE_NAME ."
            }
        }
        stage("pushing image to dockerhub"){
            steps{
                withCredentials([usernamePassword(credentialsId:'docker_creds', passwordVariable:'DOCKER_PASS', usernameVariable:'DOCKER_US')]) {
                sh "echo $DOCKER_PASS | docker login -u $DOCKER_US --password-stdin"
                sh "docker tag $IMAGE_NAME $DOCKER_US/$IMAGE_NAME"
                sh "docker push $DOCKER_US/$IMAGE_NAME"  
}
            }
        }
        stage("Deploy docker container"){
            steps{
                sh '''
                echo "Deploying docker container"
                echo "pulling docker image from dockerhub"
                docker pull $IMAGE_NAME
                echo "Running docker container"
                docker run -d -p 8000:8000 $IMAGE_NAME
            '''
            }
        }
       
    }
}