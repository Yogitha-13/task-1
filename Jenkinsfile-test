pipeline{
    agent any
    environment{
        IMAGE_NAME = "microdegree:latest"
    }
    stages{
        stage("git checkout"){
            steps{
                echo "checking out code from git repo"
            } 
        }
        stage("Building docker image"){
            steps{
                echo "building docker image using dockerfile"
                sh "docker build -t $IMAGE_NAME ."
            }
        }
        stage("pushing image to dockerhub"){
            steps{
                withCredentials([usernamePassword(credentialsId: 'docker_creds', passwordVariable:' Dockerhub_pass', usernameVariable: 'yogithasn')]) {
                sh "echo $Dockerhub_pass | docker login -u $yogithasn --password-stdin"
                sh "docker tag $IMAGE_NAME:latest $yogithasn/$IMAGE_NAME:latest"
                sh "docker push $IMAGE_NAME:latest"  
}
            }
        }
        stage("Deploy docker container"){
            steps{
                echo "Deploying docker container"
            }
        }
       
    }
}